

fn willThrow() async {
    2 + "focc!";
    println("HEHE!");
}

fn wrapper() async {
    await willThrow();
    println("continue wrapper!");
}

fn caller() async {
    try {
        await wrapper();
        println("continue try!");
    } catch (err) {
        print "FROM CATCH!!", err;
    }
    println("Continue!!!");
}

caller();

println("Done!");

fn cb(data) {
    print "CB", data;
    return data + 1;
}

fn cbError(data) {
    print "CB ERROR", data;
}

fn add(a, b) async {
    return a + b;
}

add(0, 1)
    ->then(fn(data) {
        return data + 1;
    })
    ->then(fn(data) {
        return data * 2;
    })
    ->then(cb);
    
add(0, "foccer")
    ->error(fn(data) {
        print "THEN";
    })
    ->error(cbError);
    
println(3 > 2);
println(5 && 2);

{
    2 + 2;
    println("HEHEHE!!!!");
}

if (0) {
    println("from then");
} else {
    println("from else");
}

fn catcher() {
    switch (1003) {
        case 100:
        case 200: {
            println("Hola!");
        }
        default: println(">>> Other!");
    }
}

println(switch (100) {
    0 => "zero",
    1 => "one",
    2 => "two",
    3 => "three",
    4 => "four",
    5 => "five",
    6 => "six",
    7 => "seven",
    8 => "eight",
    9 => "nine",
    _ => "other"
});

if (2) {
    println("foo");
}

fn fact(n) {
    if (n == 0) return 1;
    
    return n * fact(n - 1);
}

catcher();

println(fact(5));

println([1, 2, 3, 4, 5]);

println({
    Hello: "World",
    World: "Hello",
    add: fn(a, b) {
        return a + b; 
    }
});

fn test() {
    try {
        return "YEH!";
        println("TRY");
    } catch (err) {
        print "CATCH";
    }
    println("FINALLY");
}

const returnArray = fn() {
    return [1, 2];
};

var x = 2, y = 3;
var [xx, yy] = returnArray();
try {
    local { a: b, c: d, e: f } = {
        a: "Dog",
        c: "Cat"
    };
    print "b", b, "d", d; 
} catch (err) {
    print "CATCH EEEEE";
}

print "unpack", xx, yy;

xx = 21;
print "unpack", xx, yy;

println(x);

println(test());

var g = 0;
while (g < 10) {
    println(g);
    g = g + 1;
}

const counter = fn() {
    local i = 0;
    return fn() {
        i = i + 1;
        return i;
    };
};


const c = counter();
println(c());
println(c());
println(c());


(fn(param) {
    println(param);
})("Hello World!");

try {
    local x = 2;
    while (x < 10) {
        try {
            try {
                println(x);
                if (x == 5)
                    break;
                x = x + 1;
            } catch (err) {
                print "CATCH";
            }
        } catch (err) {
            print "CATCH";
        }
    }
} catch (err) {
    print "CATCH";
}

const { Add: myAdd } = import("./import.obi");

println(myAdd(1, 1000), Math, Math->PI, [1,200,3][1]);


var callbacks = [
    fn(index) {
        println("from callback", index);
    },
    fn(index) {
        println("from callback", index);
    }
];

var i = 0;
while (i < callbacks->length()) {
    callbacks[i](i);
    i = i + 1;
}

var items = [];

items->push(1,2,3);

println(">>", items->peek());

items->foreach(fn(a, b) {
    println("FOREACH", a);
});

fn parent() {
    provide("name", {
        add: fn(a, b) {
            return a + b;
        }
    });
    child();
}

fn child() {
    println(">>>>>", inject("name")->add(1, 5));
}

parent();

var ll = 0;

while (ll < 10) {
    ll = ll + 1;
    if (ll == 5) continue;
    println("ll ->", ll);
}

println(~1);
println(!![]);
println(+3);
println(-4);

var xpp = 0;
var ypp = {
    prop: 0
};
var zpp = ["One", 2];

var app = zpp[1]++ * 3 + 1 + zpp[1]++ - 2 + ++zpp[1] + (zpp[1] *= 2);
var bpp = ypp->prop++ + ++ypp->prop;

println("1>>>", zpp, app);
println("2>>>", ypp, bpp);
ypp->prop = 10;
println("2>>>", ypp, bpp);
println(true, false, null);


